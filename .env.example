# Gemini Developer API Key (Recommended - No Google Cloud project/Vertex AI needed!)
GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio

# Google Cloud Config (Optional - falls back to standard key if not using Vertex AI)
PROJECT_ID=your-gcp-project-id
REGION=global
GCS_BUCKET_NAME=gemini-veo-ad-generator-output

# Model IDs
VEO_MODEL_ID=veo-3.1-generate-preview
GEMINI_MODEL=gemini-3-pro-preview
IMAGE_MODEL=gemini-3-pro-image-preview
